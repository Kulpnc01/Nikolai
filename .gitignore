# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.env

# Nikolai Specific
nervous_system/*.log
spine/*.log
*.db
*.sqlite
Nikolai_Flattened_Dump.txt

# Module Protection
# We keep the folder and its __init__, but ignore specific sub-modules
# EXCEPT for the built-in HelpDiagnosticModule
modules/*
!modules/__init__.py
!modules/HelpDiagnosticModule/

# Gemini Temporary Files (Protecting Instructions)
.gemini/tmp/
.gemini/history/
.gemini/state.json
.gemini/google_accounts.json
.gemini/oauth_creds.json

# OS/System files
NTUSER.dat*
ntuser.dat*
Thumbs.db
.DS_Store
