{
  "module_id": "shopper_assistant_node_san",
  "version": "1.0.0",
  "capabilities": [
    "ui_introspection",
    "ocr_extraction",
    "route_overlay",
    "ble_haptic_trigger",
    "webrtc_stream"
  ],
  "interfaces": {
    "telemetry": {
      "protocol": "protobuf",
      "transport": "grpc",
      "encryption": "wireguard"
    },
    "automation": {
      "protocol": "json_rpc_over_ipc",
      "transport": "unix_socket"
    }
  },
  "security_policy": {
    "local_processing_required": true,
    "encrypted_transport_required": true,
    "uid_isolation": true
  }
}
